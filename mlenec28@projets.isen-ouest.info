import pandas as pd
import mysql.connector

# Paramètres MySQL
config = {
    'user': 'mlenec28',
    'password': 'PncZ9n6YUYINXnG_',
    'host': 'localhost',
    'database': 'mlenec28', # Vérifiez si c'est la bonne base pour ces données
    'charset': 'utf8mb4'
